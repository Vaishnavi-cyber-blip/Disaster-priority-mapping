    "from torch import nn\n",
    "trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "total     = sum(p.numel() for p in model.parameters())\n",
    "print(f\"Trainable params: {trainable:,} / {total:,} ({100*trainable/total:.2f}%)\")\n",
    "\n",
    "# ── 2. Use a proper learning rate with warmup ──────────────────────────────\n",
    "optimizer = torch.optim.AdamW(\n",
    "    [p for p in model.parameters() if p.requires_grad],\n",
    "    lr=1e-5,\n",
    "    weight_decay=0.01\n",
    ")\n",
    "scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=10)\n",
    "\n",
    "# ── 3. Proper CLIP contrastive loss ───────────────────────────────────────\n",
    "def clip_loss(image_features, text_features, logit_scale):\n",
    "    \"\"\"Symmetric cross-entropy contrastive loss.\"\"\"\n",
    "    logit_scale = logit_scale.exp().clamp(max=100)\n",
    "    logits_per_image = logit_scale * image_features @ text_features.T\n",
    "    logits_per_text  = logits_per_image.T\n",
    "    \n",
    "    n = logits_per_image.shape[0]\n",
    "    labels = torch.arange(n, device=logits_per_image.device)\n",
    "    \n",
    "    loss_img  = nn.CrossEntropyLoss()(logits_per_image, labels)\n",
    "    loss_text = nn.CrossEntropyLoss()(logits_per_text,  labels)\n",
    "    return (loss_img + loss_text) / 2\n",
    "\n",
    "# ── 4. Training loop with validation metric ───────────────────────────────\n",
    "# def evaluate(model, image_embeddings, text_embeddings, k=5):\n",
    "#     \"\"\"\n",
    "#     Image-to-text retrieval Recall@K — your validation metric.\n",
    "#     For each image, rank all texts by similarity, check if \n",
    "#     the correct text is in the top-K results.\n",
    "#     \"\"\"\n",
    "#     model.eval()\n",
    "#     with torch.no_grad():\n",
    "#         sim = image_embeddings @ text_embeddings.T  # (N_img, N_text)\n",
    "#         topk = sim.topk(k, dim=1).indices           # (N_img, K)\n",
    "#         targets = torch.arange(len(image_embeddings))\n",
    "#         correct = (topk == targets.unsqueeze(1)).any(dim=1).float()\n",
    "#         recall_at_k = correct.mean().item()\n",
    "#     return recall_at_k\n",
    "import os\n",
    "\n",
    "SAVE_DIR = '/kaggle/working/checkpoints'\n",
    "os.makedirs(SAVE_DIR, exist_ok=True)\n",
    "def evaluate(model, val_loader, tokenizer, device, k=5):\n",
    "    model.eval()\n",
    "    all_img_feats, all_txt_feats = [], []\n",
    "\n",
    "    with torch.no_grad():\n",
    "        for images, texts in val_loader:\n",
    "            images = images.to(device)\n",
    "            tokens = tokenizer(texts).to(device)\n",
    "            with torch.amp.autocast(device_type='cuda'):\n",
    "                img_f = model.encode_image(images)\n",
    "                txt_f = model.encode_text(tokens)\n",
    "            img_f = img_f / img_f.norm(dim=-1, keepdim=True)\n",
    "            txt_f = txt_f / txt_f.norm(dim=-1, keepdim=True)\n",
    "            all_img_feats.append(img_f.cpu().float())\n",
    "            all_txt_feats.append(txt_f.cpu().float())\n",
    "\n",
    "    img_feats = torch.cat(all_img_feats)\n",
    "    txt_feats = torch.cat(all_txt_feats)\n",
    "\n",
    "    sim    = img_feats @ txt_feats.T\n",
    "    topk   = sim.topk(k, dim=1).indices\n",
    "    labels = torch.arange(len(img_feats))\n",
    "    recall = (topk == labels.unsqueeze(1)).any(dim=1).float().mean().item()\n",
    "    return recall\n",
    "\n",
    "best_recall = 0.0\n",
    "for epoch in range(10):\n",
    "    model.train()\n",
    "    total_loss = 0\n",
    "    for batch in tqdm(dataloader):\n",
    "        images, texts = batch\n",
    "        images = images.to(device)\n",
    "        tokens = tokenizer(texts).to(device)\n",
    "        \n",
    "        optimizer.zero_grad()\n",
    "        with torch.amp.autocast(device_type='cuda'):\n",
    "            image_feat = model.encode_image(images)\n",
    "            text_feat  = model.encode_text(tokens)\n",
    "            image_feat = image_feat / image_feat.norm(dim=-1, keepdim=True)\n",
    "            text_feat  = text_feat  / text_feat.norm(dim=-1, keepdim=True)\n",
    "            loss = clip_loss(image_feat, text_feat, model.logit_scale)\n",
    "        \n",
    "        loss.backward()\n",
    "        torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)\n",
    "        optimizer.step()\n",
    "        total_loss += loss.item()\n",
    "    \n",
    "    scheduler.step()\n",
    "    avg_loss = total_loss / len(dataloader)\n",
    "    \n",
    "    # Compute validation recall@5\n",
    "    recall = evaluate(model, val_loader, tokenizer, device, k=5)\n",
    "    # ── Save best model ────────────────────────────────────────────────────\n",
    "    if recall > best_recall:\n",
    "        best_recall = recall\n",
    "        torch.save({\n",
    "            'epoch':       epoch + 1,\n",
    "            'model_state': model.state_dict(),\n",
    "            'optimizer':   optimizer.state_dict(),\n",
    "            'recall':      best_recall,\n",
    "            'loss':        avg_loss,\n",
    "        }, f'{SAVE_DIR}/best_model.pt')\n",
    "        print(f\"Epoch {epoch+1} | Loss: {avg_loss:.4f} | Recall@5: {recall:.4f} ✅ saved\")\n",
    "    else:\n",
    "        print(f\"Epoch {epoch+1} | Loss: {avg_loss:.4f} | Recall@5: {recall:.4f}\")\n",
    "\n",
    "print(f\"\\nBest Recall@5: {best_recall:.4f}\")\n",
    "print(f\"Model saved to: {SAVE_DIR}/best_model.pt\")"
   ]
  },
