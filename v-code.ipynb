   "source": [
    "# ── CELL 10: Cosine similarity matrix (tweets × tiles) ─────────────────────────\n",
    "# S[t, i] = similarity between tweet t and image tile i\n",
    "# Both are already L2-normalized so dot product = cosine similarity\n",
    "\n",
    "print(\"Computing similarity matrix...\")\n",
    "S = text_embeddings @ image_embeddings.T  # shape: (n_tweets, n_tiles)\n",
    "print(f\"Similarity matrix shape: {S.shape}\")\n",
    "print(f\"Similarity range: [{S.min():.3f}, {S.max():.3f}]\")\n",
    "\n",
    "# Per-tile: average similarity across all crisis tweets\n",
    "tile_scores = S.mean(dim=0).numpy()   # shape: (n_tiles,)\n",
    "\n",
    "# Normalize to [0, 1]\n",
    "tile_scores_norm = (tile_scores - tile_scores.min()) / (tile_scores.max() - tile_scores.min() + 1e-8)\n",
    "\n",
    "# Apply disaster-relevance weights\n",
    "weights = np.array([DISASTER_RELEVANT_CLASSES.get(cls, 1.0) for cls in all_classes])\n",
    "tile_scores_weighted = tile_scores_norm * weights\n",
    "tile_scores_weighted = (tile_scores_weighted - tile_scores_weighted.min()) / \\\n",
    "                       (tile_scores_weighted.max() - tile_scores_weighted.min() + 1e-8)\n",
    "\n",
    "print(\"\\nMean priority score per land-use class:\")\n",
    "results_df = pd.DataFrame({'class': all_classes, 'raw_score': tile_scores_norm, 'weighted_score': tile_scores_weighted})\n",
    "class_summary = results_df.groupby('class')['weighted_score'].agg(['mean', 'max']).sort_values('mean', ascending=False)\n",
    "print(class_summary.round(4))"
   ]
  },
