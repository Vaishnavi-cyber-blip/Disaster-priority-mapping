    "# ── CELL 7: Geocode top locations ───────────────────────────────\n",
    "# We geocode the top mentioned locations to get lat/lon for the map\n",
    "geolocator = Nominatim(user_agent='disaster_priority_mapper')\n",
    "geocode = RateLimiter(geolocator.geocode, min_delay_seconds=1.1)\n",
    "\n",
    "top_locations = [loc for loc, _ in loc_counts.most_common(20)]\n",
    "geo_results = {}\n",
    "\n",
    "print(\"Geocoding locations...\")\n",
    "for loc in tqdm(top_locations):\n",
    "    try:\n",
    "        result = geocode(loc)\n",
    "        if result:\n",
    "            geo_results[loc] = (result.latitude, result.longitude)\n",
    "    except Exception as e:\n",
    "        print(f\"  Could not geocode '{loc}': {e}\")\n",
    "\n",
    "print(f\"\\nSuccessfully geocoded {len(geo_results)}/{len(top_locations)} locations\")\n",
    "for loc, (lat, lon) in list(geo_results.items())[:8]:\n",
    "    print(f\"  {loc}: ({lat:.3f}, {lon:.3f})\")"
   ]
