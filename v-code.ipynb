    "sample_crisis_scored['max_image_sim']  = tweet_max_sim\n",
    "sample_crisis_scored['mean_image_sim'] = tweet_mean_sim\n",
    "sample_crisis_scored['alarm_score']    = (tweet_max_sim + tweet_mean_sim) / 2\n",
