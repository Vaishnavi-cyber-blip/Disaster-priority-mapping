   "source": [
    "# ── CELL 16: Render Folium interactive map ─────────────────────────────────────\n",
    "def priority_color(score):\n",
    "    \"\"\"Map score [0,1] to color string.\"\"\"\n",
    "    if score > 0.75: return '#ff1744'   # critical\n",
    "    elif score > 0.5: return '#ff6d00'  # high\n",
    "    elif score > 0.25: return '#ffd600' # medium\n",
    "    else: return '#00c853'              # low\n",
    "\n",
    "# Center map on mean location\n",
    "center_lat = loc_df['lat'].mean()\n",
    "center_lon = loc_df['lon'].mean()\n",
    "\n",
    "m = folium.Map(\n",
    "    location=[center_lat, center_lon],\n",
    "    zoom_start=3,\n",
    "    tiles='CartoDB dark_matter'\n",
    ")\n",
    "\n",
    "# Add heatmap layer\n",
    "heat_data = [[row['lat'], row['lon'], row['priority_norm']]\n",
    "             for _, row in loc_df.iterrows()]\n",
    "HeatMap(\n",
    "    heat_data,\n",
    "    min_opacity=0.4,\n",
    "    max_zoom=10,\n",
    "    radius=40,\n",
    "    blur=25,\n",
    "    gradient={0.2: 'blue', 0.4: 'lime', 0.6: 'yellow', 0.8: 'orange', 1.0: 'red'}\n",
    ").add_to(m)\n",
    "\n",
    "# Add circle markers for each location\n",
    "for _, row in loc_df.iterrows():\n",
    "    color = priority_color(row['priority_norm'])\n",
    "    radius = 8 + row['priority_norm'] * 20  # bigger = more urgent\n",
    "    \n",
    "    popup_html = f\"\"\"\n",
    "    <div style='font-family:monospace; background:#1a1a2e; color:#e0e0e0; \n",
    "                padding:10px; border-radius:8px; min-width:200px;'>\n",
    "        <b style='color:{color}; font-size:14px;'>⚠ {row['location']}</b><br>\n",
    "        <hr style='border-color:#333;'/>\n",
    "        <b>Priority Score:</b> {row['priority_norm']:.3f}<br>\n",
    "        <b>Crisis Tweets:</b> {int(row.get('tweet_count', 0))}<br>\n",
    "        <b>Avg Alarm:</b> {row.get('avg_alarm', 0):.3f}<br>\n",
    "        <b>Coordinates:</b> ({row['lat']:.3f}, {row['lon']:.3f})\n",
    "    </div>\"\"\"\n",
    "    \n",
    "    folium.CircleMarker(\n",
    "        location=[row['lat'], row['lon']],\n",
    "        radius=radius,\n",
    "        color=color,\n",
    "        fill=True,\n",
    "        fill_color=color,\n",
    "        fill_opacity=0.7,\n",
    "        weight=2,\n",
    "        popup=folium.Popup(folium.IFrame(popup_html, width=240, height=160), max_width=260),\n",
    "        tooltip=f\"{row['location']}: {row['priority_norm']:.2f}\"\n",
    "    ).add_to(m)\n",
    "\n",
    "# Legend\n",
    "legend_html = \"\"\"\n",
    "<div style=\"position:fixed; bottom:40px; left:40px; z-index:9999;\n",
    "            background:#1a1a2e; border:2px solid #333; border-radius:10px;\n",
    "            padding:15px; font-family:monospace; color:#e0e0e0; font-size:12px;\">\n",
    "    <b style='color:#fff; font-size:14px;'>🛰 Priority Map</b><br>\n",
    "    <b style='color:#aaa; font-size:11px;'>CLIP Satellite-Tweet Alignment</b><br><br>\n",
    "    <span style='color:#ff1744;'>● CRITICAL (>0.75)</span><br>\n",
    "    <span style='color:#ff6d00;'>● HIGH (0.50–0.75)</span><br>\n",
    "    <span style='color:#ffd600;'>● MEDIUM (0.25–0.50)</span><br>\n",
    "    <span style='color:#00c853;'>● LOW (<0.25)</span><br>\n",
    "</div>\"\"\"\n",
    "m.get_root().html.add_child(folium.Element(legend_html))\n",
    "\n",
    "MAP_PATH = '/kaggle/working/disaster_priority_map.html'\n",
    "m.save(MAP_PATH)\n",
    "print(f\"✅ Interactive map saved: {MAP_PATH}\")\n",
    "print(\"   Open this HTML file in a browser to explore the priority map!\")\n",
    "m  # display inline in Kaggle"
   ]
  },
