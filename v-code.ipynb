    "        img_path = self.img_paths[idx % len(self.img_paths)]\n",
    "        image = self.preprocess(Image.open(img_path).convert('RGB'))\n",
    "        text = tokenizer(self.df.iloc[idx]['clean_text'][:200])[0]\n",
    "        return image, text\n",
    "\n",
    "# Initialize DataLoader\n",
    "train_loader = DataLoader(DisasterDataset(crisis_df, all_paths, preprocess), \n",
    "                          batch_size=64, shuffle=True)"
