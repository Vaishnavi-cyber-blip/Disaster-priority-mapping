    "# ── CELL 8: Encode crisis tweets with CLIP text encoder ────────────────────────\n",
    "BATCH_SIZE = 256\n",
    "\n",
    "def encode_texts(texts, batch_size=BATCH_SIZE):\n",
    "    \"\"\"Encode a list of strings into CLIP text embeddings.\"\"\"\n",
    "    all_embeds = []\n",
    "    for i in tqdm(range(0, len(texts), batch_size), desc='Encoding texts'):\n",
    "        batch = texts[i : i + batch_size]\n",
    "        tokens = tokenizer(batch).to(device)\n",
    "        with torch.no_grad(), torch.cuda.amp.autocast():\n",
    "            embeds = model.encode_text(tokens)\n",
    "            embeds = embeds / embeds.norm(dim=-1, keepdim=True)  # L2-normalize\n",
    "        all_embeds.append(embeds.cpu().float())\n",
    "    return torch.cat(all_embeds, dim=0)\n",
    "\n",
    "# Use clean text; truncate to 77 tokens (CLIP limit) by keeping first 200 chars\n",
    "tweet_texts = sample_crisis['clean_text'].apply(lambda x: x[:200]).tolist()\n",
    "text_embeddings = encode_texts(tweet_texts)\n",
    "print(f\"Text embeddings shape: {text_embeddings.shape}\")"
   ]
  },
