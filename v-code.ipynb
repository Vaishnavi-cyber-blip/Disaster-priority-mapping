    "# ── CELL 6: Extract location entities from tweets (NER) ────────────────────────\n",
    "nlp = spacy.load('en_core_web_sm')\n",
    "\n",
    "def extract_locations(text):\n",
    "    \"\"\"Extract GPE (geo-political) and LOC entities.\"\"\"\n",
    "    doc = nlp(text)\n",
    "    locs = [ent.text for ent in doc.ents if ent.label_ in ('GPE', 'LOC', 'FAC')]\n",
    "    return locs\n",
    "\n",
    "# Sample on first 200 tweets for demo (full run takes a few minutes)\n",
    "# sample_crisis = crisis_df.head(200).copy()\n",
    "sample_crisis = crisis_df.copy()\n",
    "sample_crisis['locations'] = sample_crisis['text'].apply(extract_locations)\n",
    "\n",
    
    "if 'location' in sample_crisis.columns:\n",
    "    sample_crisis['locations'] = sample_crisis.apply(\n",
    "        lambda r: r['locations'] + ([r['location']] if isinstance(r['location'], str) else []),\n",
    "        axis=1\n",
    "    )\n",
    "\n",
    "# Counting which locations are most mentioned\n",
    "from collections import Counter\n",
    "all_locs = [loc for locs in sample_crisis['locations'] for loc in locs if loc]\n",
    "loc_counts = Counter(all_locs)\n",
    "print(\"Top 15 mentioned locations:\")\n",
    "for loc, cnt in loc_counts.most_common(15):\n",
    "    print(f\"  {loc}: {cnt}\")"
   ]
  },
