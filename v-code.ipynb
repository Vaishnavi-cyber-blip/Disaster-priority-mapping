   "source": [
    "# ── CELL 15: Build the geographic priority map with Folium ─────────────────────\n",
    "# We assign each geocoded location a priority score based on:\n",
    "#   1. How many crisis tweets mention it\n",
    "#   2. The average alarm score of those tweets\n",
    "\n",
    "# Build location → alarm scores mapping\n",
    "loc_alarm_scores = {loc: [] for loc in geo_results}\n",
    "\n",
    "for _, row in sample_crisis_scored.iterrows():\n",
    "    for loc in (row.get('locations') or []):\n",
    "        if loc in loc_alarm_scores:\n",
    "            loc_alarm_scores[loc].append(row['alarm_score_norm'])\n",
    "\n",
    "# Compute priority per location\n",
    "location_priority = []\n",
    "for loc, (lat, lon) in geo_results.items():\n",
    "    scores = loc_alarm_scores.get(loc, [])\n",
    "    if scores:\n",
    "        priority = np.mean(scores) * np.log1p(len(scores))  # combine intensity + frequency\n",
    "    else:\n",
    "        priority = 0.1  # small baseline for geocoded but non-mentioned\n",
    "    mention_count = len(scores)\n",
    "    location_priority.append({\n",
    "        'location': loc, 'lat': lat, 'lon': lon,\n",
    "        'priority': priority, 'tweet_count': mention_count,\n",
    "        'avg_alarm': np.mean(scores) if scores else 0\n",
    "    })\n",
    "\n",
    "loc_df = pd.DataFrame(location_priority)\n",
    "if not loc_df.empty:\n",
    "    loc_df['priority_norm'] = (loc_df['priority'] - loc_df['priority'].min()) / \\\n",
    "                               (loc_df['priority'].max() - loc_df['priority'].min() + 1e-8)\n",
    "    print(\"Location priority table:\")\n",
    "    print(loc_df.sort_values('priority_norm', ascending=False)\n",
    "          [['location', 'lat', 'lon', 'priority_norm', 'tweet_count', 'avg_alarm']].to_string(index=False))\n",
    "else:\n",
    "    # Fallback: create synthetic disaster hotspots for demo\n",
    "    print(\"No geocoded locations found — using synthetic disaster hotspots for demo\")\n",
    "    loc_df = pd.DataFrame([\n",
    "        {'location': 'Nepal', 'lat': 28.39, 'lon': 84.12, 'priority_norm': 0.95, 'tweet_count': 45, 'avg_alarm': 0.82},\n",
    "        {'location': 'Houston', 'lat': 29.76, 'lon': -95.37, 'priority_norm': 0.88, 'tweet_count': 38, 'avg_alarm': 0.77},\n",
    "        {'location': 'Puerto Rico', 'lat': 18.22, 'lon': -66.59, 'priority_norm': 0.79, 'tweet_count': 29, 'avg_alarm': 0.70},\n",
    "        {'location': 'California', 'lat': 36.78, 'lon': -119.42, 'priority_norm': 0.65, 'tweet_count': 20, 'avg_alarm': 0.61},\n",
    "        {'location': 'Japan', 'lat': 36.20, 'lon': 138.25, 'priority_norm': 0.50, 'tweet_count': 14, 'avg_alarm': 0.52},\n",
    "        {'location': 'Philippines', 'lat': 12.88, 'lon': 121.77, 'priority_norm': 0.42, 'tweet_count': 11, 'avg_alarm': 0.46},\n",
    "    ])"
   ]
