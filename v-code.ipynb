   "source": [
    "# ── CELL 9: Load EuroSAT tiles & encode with CLIP image encoder ───────────────\n",
    "# We sample N images per class to keep runtime reasonable\n",
    "SAMPLES_PER_CLASS = 2000  # increase if you have GPU\n",
    "\n",
    "EUROSAT_CLASSES = [\n",
    "    'AnnualCrop', 'Forest', 'HerbaceousVegetation', 'Highway',\n",
    "    'Industrial', 'Pasture', 'PermanentCrop', 'Residential',\n",
    "    'River', 'SeaLake'\n",
    "]\n",
    "\n",
    "# Disaster-relevant classes get extra weight later\n",
    "DISASTER_RELEVANT_CLASSES = {\n",
    "    'Residential': 1.5,   # populated areas\n",
    "    'Industrial':  1.3,\n",
    "    'Highway':     1.2,\n",
    "    'River':       1.4,   # flood-prone\n",
    "    'SeaLake':     1.2,\n",
    "    'Forest':      1.1,\n",
    "    'AnnualCrop':  1.0,\n",
    "    'HerbaceousVegetation': 0.9,\n",
    "    'Pasture':     0.9,\n",
    "    'PermanentCrop': 0.9,\n",
    "}\n",
    "\n",
    "tile_records = []   # {path, class_name, embedding}\n",
    "tile_images_for_viz = []  # store a few for visualization\n",
    "\n",
    "def encode_images(image_paths, batch_size=128):\n",
    "    \"\"\"Encode image files into CLIP image embeddings.\"\"\"\n",
    "    all_embeds = []\n",
    "    for i in tqdm(range(0, len(image_paths), batch_size), desc='Encoding images'):\n",
    "        batch_paths = image_paths[i : i + batch_size]\n",
    "        imgs = []\n",
    "        for p in batch_paths:\n",
    "            try:\n",
    "                img = preprocess(Image.open(p).convert('RGB'))\n",
    "                imgs.append(img)\n",
    "            except Exception:\n",
    "                imgs.append(torch.zeros(3, 224, 224))  # fallback blank\n",
    "        batch_tensor = torch.stack(imgs).to(device)\n",
    "        with torch.no_grad(), torch.cuda.amp.autocast():\n",
    "            embeds = model.encode_image(batch_tensor)\n",
    "            embeds = embeds / embeds.norm(dim=-1, keepdim=True)\n",
    "        all_embeds.append(embeds.cpu().float())\n",
    "    return torch.cat(all_embeds, dim=0)\n",
    "\n",
    "# Collect image paths\n",
    "all_paths, all_classes = [], []\n",
    "for cls in EUROSAT_CLASSES:\n",
    "    cls_dir = os.path.join(EUROSAT_IMG, cls)\n",
    "    if not os.path.exists(cls_dir):\n",
    "        print(f\"  WARNING: {cls_dir} not found, skipping\")\n",
    "        continue\n",
    "    imgs = glob.glob(os.path.join(cls_dir, '*.jpg')) + \\\n",
    "           glob.glob(os.path.join(cls_dir, '*.png')) + \\\n",
    "           glob.glob(os.path.join(cls_dir, '*.jpeg'))\n",
    "    sampled = random.sample(imgs, min(SAMPLES_PER_CLASS, len(imgs)))\n",
    "    all_paths.extend(sampled)\n",
    "    all_classes.extend([cls] * len(sampled))\n",
    "\n",
    "print(f\"Total tiles to encode: {len(all_paths)}\")\n",
    "\n",
    "if len(all_paths) > 0:\n",
    "    image_embeddings = encode_images(all_paths)\n",
    "    print(f\"Image embeddings shape: {image_embeddings.shape}\")\n",
    "else:\n",
    "    print(\"No images found! Using synthetic embeddings for demo.\")\n",
    "    # Fallback: create random embeddings for testing\n",
    "    n_fake = len(EUROSAT_CLASSES) * SAMPLES_PER_CLASS\n",
    "    image_embeddings = torch.randn(n_fake, 512)\n",
    "    image_embeddings = image_embeddings / image_embeddings.norm(dim=-1, keepdim=True)\n",
    "    all_classes = [cls for cls in EUROSAT_CLASSES for _ in range(SAMPLES_PER_CLASS)]"
   ]
  },
