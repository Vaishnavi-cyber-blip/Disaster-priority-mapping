    "# ── CELL 14: Semantic clusters — what disaster themes appear in tweets ──────────\n",
    "# Defining semantic query templates that match disaster scenarios\n",
    "DISASTER_QUERIES = [\n",
    "    \"flooded residential area\",\n",
    "    \"fire and smoke industrial zone\",\n",
    "    \"collapsed highway bridge\",\n",
    "    \"earthquake damaged buildings\",\n",
    "    \"tsunami flooding coastal\",\n",
    "    \"wildfire forest burning\",\n",
    "    \"tornado destroyed farmland\",\n",
    "    \"hurricane storm damage\",\n",
    "    \"people need rescue urgent help\",\n",
    "    \"infrastructure damage road blocked\",\n",
    "]\n",
    "\n",
    "# Encode the disaster query templates\n",
    "query_embeds = encode_texts(DISASTER_QUERIES, batch_size=16)\n",
    "\n",
    "# For each query, we find which tiles match best (theme → tile mapping)\n",
    "query_tile_sim = query_embeds @ image_embeddings.T  # (n_queries, n_tiles)\n",
    "\n",
    "print(\"\\nTop matching tile class for each disaster theme:\")\n",
    "for q_idx, query in enumerate(DISASTER_QUERIES):\n",
    "    sims = query_tile_sim[q_idx].numpy()\n",
    "    top_tile_idx = np.argmax(sims)\n",
    "    top_class    = all_classes[top_tile_idx]\n",
    "    top_score    = sims[top_tile_idx]\n",
    "    # Class-level average\n",
    "    class_avgs = {cls: sims[[i for i, c in enumerate(all_classes) if c == cls]].mean()\n",
    "                  for cls in set(all_classes)}\n",
    "    top_cls_avg = max(class_avgs, key=class_avgs.get)\n",
    "    print(f\"  '{query}'\")\n",
    "    print(f\"    → Best tile: {top_class} (score: {top_score:.3f}) | Best class avg: {top_cls_avg}\")"
   ]
