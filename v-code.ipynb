   "source": [
    "# ── CELL 17: Static heatmap grid (matplotlib) ──────────────────────────────────\n",
    "# Build a grid of class-level priority scores for a clean summary figure\n",
    "\n",
    "# Class priority summary\n",
    "class_scores = results_df.groupby('class')['weighted_score'].mean().to_dict()\n",
    "\n",
    "# Create a 3x4 grid layout of land-use classes\n",
    "grid_layout = [\n",
    "    ['Forest',        'HerbaceousVegetation', 'AnnualCrop',  'PermanentCrop'],\n",
    "    ['Pasture',       'SeaLake',              'River',       'Highway'],\n",
    "    ['Residential',   'Industrial',           'AnnualCrop',  'Forest'],\n",
    "]\n",
    "\n",
    "score_grid = np.array([[class_scores.get(cls, 0) for cls in row] for row in grid_layout])\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(14, 6))\n",
    "fig.patch.set_facecolor('#0d1117')\n",
    "ax.set_facecolor('#0d1117')\n",
    "\n",
    "im = ax.imshow(score_grid, cmap='hot', vmin=0, vmax=1, aspect='auto')\n",
    "ax.set_xticks(range(4))\n",
    "ax.set_xticklabels([c.replace('Herbaceous', 'Herb.') for c in grid_layout[0]], \n",
    "                   color='#8b949e', fontsize=10)\n",
    "ax.set_yticks(range(3))\n",
    "ax.set_yticklabels(['Zone A (Vegetation)', 'Zone B (Water/Roads)', 'Zone C (Urban)'],\n",
    "                   color='#8b949e', fontsize=10)\n",
    "\n",
    "# Annotate each cell\n",
    "for i in range(3):\n",
    "    for j in range(4):\n",
    "        cls   = grid_layout[i][j]\n",
    "        score = score_grid[i, j]\n",
    "        ax.text(j, i, f'{cls}\\n{score:.2f}',\n",
    "                ha='center', va='center', fontsize=8,\n",
    "                color='white' if score > 0.5 else '#aaa', fontweight='bold')\n",
    "\n",
    "cbar = plt.colorbar(im, ax=ax, fraction=0.03, pad=0.02)\n",
    "cbar.set_label('Crisis Priority Score', color='#e6edf3', fontsize=11)\n",
    "cbar.ax.yaxis.set_tick_params(color='#8b949e')\n",
    "plt.setp(cbar.ax.yaxis.get_ticklabels(), color='#8b949e')\n",
    "\n",
    "ax.set_title('🛰  Geographic Priority Grid — Land Use × Crisis Alignment',\n",
    "             color='#e6edf3', fontsize=14, fontweight='bold', pad=15)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('/kaggle/working/priority_grid.png', dpi=150, bbox_inches='tight', facecolor='#0d1117')\n",
    "plt.show()\n",
    "print(\"Saved: priority_grid.png\")"
   ]
  },
