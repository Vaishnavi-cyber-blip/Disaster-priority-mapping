    "# ── CELL 5: Load & clean tweets ──────────────\n",
    "df = pd.read_csv(TWEET_CSV)\n",
    "print(f\"Total tweets: {len(df)}\")\n",
    "print(df.head(3))\n",
    "print(\"\\nClass distribution:\")\n",
    "print(df['target'].value_counts())\n",
    "\n",
    "def clean_tweet(text):\n",
    "    \"\"\"Remove URLs, @mentions, special characters, lowercase.\"\"\"\n",
    "    if not isinstance(text, str): return ''\n",
    "    text = re.sub(r'http\\S+|www\\S+', '', text)\n",
    "    text = re.sub(r'@\\w+', '', text)\n",
    "    text = re.sub(r'#(\\w+)', r'\\1', text)  # keep hashtag words\n",
    "    text = re.sub(r'[^\\w\\s.,!?]', ' ', text)\n",
    "    text = re.sub(r'\\s+', ' ', text).strip()\n",
    "    return text.lower()\n",
    "\n",
    "df['clean_text'] = df['text'].apply(clean_tweet)\n",
    "\n",
    "# Kept only actual disaster tweets (target=1) for the priority map\n",
    "crisis_df = df[df['target'] == 1].copy().reset_index(drop=True)\n",
    "print(f\"\\nCrisis tweets (target=1): {len(crisis_df)}\")\n",
    "\n",
    "# Preview\n",
    "crisis_df[['text', 'clean_text']].head(5)"
   ]
  },
